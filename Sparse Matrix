#include <stdio.h>

int main() {
    int matrix[4][4] = {
        {0, 0, 0, 5},
        {0, 8, 0, 0},
        {0, 0, 0, 0},
        {0, 0, 3, 0}
    };

    int size = 0;

    // Count non-zero elements
    for(int i = 0; i < 4; i++) {
        for(int j = 0; j < 4; j++) {
            if(matrix[i][j] != 0)
                size++;
        }
    }

    int sparse[size + 1][3];

    // Header row
    sparse[0][0] = 4;
    sparse[0][1] = 4;
    sparse[0][2] = size;

    int k = 1;

    // Store non-zero elements
    for(int i = 0; i < 4; i++) {
        for(int j = 0; j < 4; j++) {
            if(matrix[i][j] != 0) {
                sparse[k][0] = i;
                sparse[k][1] = j;
                sparse[k][2] = matrix[i][j];
                k++;
            }
        }
    }

    // Print sparse matrix
    printf("Sparse Matrix Representation:\n");
    for(int i = 0; i < size + 1; i++) {
        printf("%d %d %d\n", sparse[i][0], sparse[i][1], sparse[i][2]);
    }

    return 0;
}
